generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String           @id @default(cuid())
  email          String?          @unique
  phone          String           @unique
  createdAt      DateTime         @default(now())
  address        String?
  avatarUrl      String?
  city           String?
  fullName       String
  passwordHash   String
  role           String
  messagesSent   Message[]
  notifications  Notification[]
  reviewsWritten Review[]
  requestsMade   ServiceRequest[] @relation("ClientRequests")
  technician     Technician?
  pushSubscriptions PushSubscription[]
}

model Technician {
  id               String           @id @default(cuid())
  userId           String           @unique
  title            String
  bio              String?
  yearsExperience  Int              @default(0)
  startingPrice    Int              @default(0)
  latitude         Float            @default(36.8065)
  longitude        Float            @default(10.1815)
  verified         Boolean          @default(false)
  galleryImages    String?
  planId           String?
  createdAt        DateTime         @default(now())
  payments         Payment[]
  reviews          Review[]         @relation("TechnicianReviews")
  requestsReceived ServiceRequest[] @relation("TechnicianRequests")
  subscriptions    Subscription[]
  plan             Plan?            @relation(fields: [planId], references: [id])
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories       Category[]       @relation("CategoryToTechnician")
}

model Category {
  id          String           @id @default(cuid())
  name        String
  slug        String           @unique
  icon        String
  description String?
  color       String
  howItWorks  String?
  ratingAvg   Float?
  ratingCount Int?
  sortOrder   Int              @default(0)
  videoUrl    String?
  requests    ServiceRequest[]
  technicians Technician[]     @relation("CategoryToTechnician")
}

model ServiceRequest {
  id                    String     @id @default(cuid())
  clientId              String
  technicianId          String
  categoryId            String
  fullName              String
  phone                 String
  address               String
  latitude              Float?
  longitude             Float?
  description           String
  photos                String?
  status                String     @default("PENDING")
  clientConfirmedSolved Boolean?
  pendingAt             DateTime   @default(now())
  acceptedAt            DateTime?
  onTheWayAt            DateTime?
  arrivedAt             DateTime?
  inProgressAt          DateTime?
  completedAt           DateTime?
  declinedAt            DateTime?
  cancelledAt           DateTime?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  messages              Message[]
  payment               Payment?
  review                Review?
  category              Category   @relation(fields: [categoryId], references: [id])
  client                User       @relation("ClientRequests", fields: [clientId], references: [id])
  technician            Technician @relation("TechnicianRequests", fields: [technicianId], references: [id])
}

model Message {
  id        String         @id @default(cuid())
  requestId String
  senderId  String
  body      String?
  imageUrl  String?
  createdAt DateTime       @default(now())
  request   ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  sender    User           @relation(fields: [senderId], references: [id])
}

model Review {
  id           String         @id @default(cuid())
  requestId    String         @unique
  technicianId String
  rating       Int
  comment      String?
  createdAt    DateTime       @default(now())
  authorId     String
  author       User           @relation(fields: [authorId], references: [id])
  request      ServiceRequest @relation(fields: [requestId], references: [id])
  technician   Technician     @relation("TechnicianReviews", fields: [technicianId], references: [id])
}

model Plan {
  id                  String         @id @default(cuid())
  key                 String         @unique
  name                String
  price               Int
  billingCycle        String
  commissionRate      Float
  maxRequestsPerMonth Int?
  priorityVisibility  Boolean        @default(false)
  features            String
  badge               String?
  subscriptions       Subscription[]
  technicians         Technician[]
}

model Subscription {
  id           String     @id @default(cuid())
  technicianId String
  planId       String
  startedAt    DateTime   @default(now())
  expiresAt    DateTime?
  status       String     @default("ACTIVE")
  plan         Plan       @relation(fields: [planId], references: [id])
  technician   Technician @relation(fields: [technicianId], references: [id])
}

model Payment {
  id           String          @id @default(cuid())
  requestId    String?         @unique
  amount       Int
  method       String
  status       String          @default("PAID")
  createdAt    DateTime        @default(now())
  platformFee  Int             @default(0)
  technicianId String
  type         String
  request      ServiceRequest? @relation(fields: [requestId], references: [id])
  technician   Technician      @relation(fields: [technicianId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String?
  requestId String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}